<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_won_view_form" model="ir.ui.view">
        <field name="name">crm.lead.won.form</field>
        <field name="model">crm.lead.won</field>
        <field name="arch" type="xml">
            <form string="Mark as Won">
                <field name="lead_id" invisible="1"/>
                <group>
                    <field name="won_reason_ids" widget="many2many_tags" 
                           options="{'no_create_edit': True}"
                           placeholder="Why did we win?"/>
                    <field name="won_feedback" placeholder="Add some feedback..."/>
                </group>
                <footer>
                    <button name="action_won_reason_apply" string="Congratulations! Mark as Won" type="object" class="btn-primary"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
